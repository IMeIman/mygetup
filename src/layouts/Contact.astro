---
import Form from "../components/Form.astro";

interface Props {
    title?: string;
    description?: string;
    mapLat?: number;
    mapLng?: number;
    mapZoom?: number;
    contactEmail?: string;
    contactPhone?: string;
    address?: string;
}

const {
    title = "Contacto",
    description = "¿Tienes preguntas? Nos encantaría escucharte.",
    mapLat = 40.4168,
    mapLng = -3.7038,
    mapZoom = 13,
    contactEmail,
    contactPhone,
    address
} = Astro.props;

const fields = [
    { name: 'nombre', label: 'Nombre Completo', type: 'text' as const, required: true },
    { name: 'email', label: 'Email', type: 'email' as const, required: true },
    { name: 'telefono', label: 'Teléfono', type: 'text' as const, required: false },
    { name: 'mensaje', label: 'Mensaje', type: 'textarea' as const, required: true }
];
---

<section class="flex flex-row justify-center">
    <div class="container flex flex-col w-11/12 gap-8 pt-24 pb-24">
        <!-- Header -->
        <div class="flex flex-col gap-4 mb-8">
            <h1 class="text-4xl md:text-5xl font-semibold text-gray-900">{title}</h1>
            <p class="text-lg text-gray-600">{description}</p>
        </div>

        <!-- Grid Layout -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
            <!-- Form Column -->
            <div class="flex flex-col gap-6">
                <h2 class="text-2xl font-semibold text-gray-900">Envíanos un mensaje</h2>
                <Form 
                    fields={fields}
                    submitLabel="Enviar Mensaje"
                    method="POST"
                    onSubmit="/api/contact"
                />
            </div>
            <div class="md:col-start-2 md:col-end-3">
                <div class="flex flex-col gap-4">
                <h2 class="text-2xl font-semibold text-gray-900">Ubicación</h2>
                <iframe
                    src={`https://www.openstreetmap.org/export/embed.html?bbox=${mapLng - 0.05},${mapLat - 0.05},${mapLng + 0.05},${mapLat + 0.05}&layer=mapnik&marker=${mapLat},${mapLng}`}
                    style="width: 100%; height: 250px; border: 1px solid #e5e7eb; border-radius: 0.5rem;"
                    loading="lazy"
                ></iframe>
                <div class="flex flex-col gap-6 mt-8 pt-8 border-t border-gray-200">
                    <h3 class="text-lg font-semibold text-gray-900">Información de Contacto</h3>
                    
                    {contactEmail && (
                        <div class="flex flex-col gap-1">
                            <p class="text-sm text-gray-600">Email</p>
                            <a 
                                href={`mailto:${contactEmail}`}
                                class="text-violet-500 hover:text-violet-600 font-medium transition-colors"
                            >
                                {contactEmail}
                            </a>
                        </div>
                    )}

                    {contactPhone && (
                        <div class="flex flex-col gap-1">
                            <p class="text-sm text-gray-600">Teléfono</p>
                            <a 
                                href={`tel:${contactPhone}`}
                                class="text-violet-500 hover:text-violet-600 font-medium transition-colors"
                            >
                                {contactPhone}
                            </a>
                        </div>
                    )}

                    {address && (
                        <div class="flex flex-col gap-1">
                            <p class="text-sm text-gray-600">Dirección</p>
                            <p class="text-gray-900 font-medium">{address}</p>
                        </div>
                    )}
                </div>
            </div>
            </div>
        </div>
        
    </div>
</section>

<style>
    iframe {
        display: block;
    }
</style>
