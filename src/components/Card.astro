---
import type { url } from 'astro:schema';
import Button from './Button.astro';

interface Props {
    title: string;
    description: string;
    button?: boolean;
    buttonLabel?: string;
    buttonVariant?: 'primary' | 'secondary';
    imageUrl?: string;
    imageAlt?: string;
}
const {
    title,
    description,
    button = false,
    buttonLabel = 'Botón',
    buttonVariant = 'primary',
    imageUrl,
    imageAlt
    } = Astro.props;
---
<div class="flex flex-col rounded-2xl gap-8 shadow-md overflow-hidden justify-between h-full">
    <div class="flex flex-col gap-4 p-4">
        <h3 class="text-3xl">{title}</h3>
        <p>{description}</p>

        <div class="flex flex-col md:flex-row">
            {button && (
                <Button variant={buttonVariant} label={buttonLabel}>
                </Button>
            )}
        </div>
    </div>

    <img src={imageUrl} alt={imageAlt} class="w-full h-auto object-cover">
</div>

