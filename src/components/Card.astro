---
import { string, type url } from 'astro:schema';
import Button from './Button.astro';

interface Props {
    title: string;
    description: string;
    button?: boolean;
    buttonLabel?: string;
    buttonVariant?: 'primary' | 'secondary';
    imageUrl?: string;
    imageAlt?: string;
    li?: Li[];
    link?: Link;
}
interface Li {
    text: string;
}
interface Link {
    text: string;
    href: string;
}
const {
    title,
    description,
    button = false,
    buttonLabel = 'Botón',
    buttonVariant = 'primary',
    imageUrl,
    imageAlt,
    li = [],
    link
    } = Astro.props;
---
<div class="flex flex-col gap-0 rounded-2xl border border-gray-100 shadow-md overflow-hidden justify-between h-full">
    <div class="flex flex-col gap-4 p-8">
        <h3 class="text-3xl">{title}</h3>
        <p>{description}</p>

        {li.length > 0 && (
        <ul class="flex flex-col gap-2">
            {li.map((li) => (
                <li class="flex flex-row gap-4 items-center">
                    <div class="bg-gray-800 w-2 h-2 rounded-full"></div>
                    <p>
                        {li.text}
                    </p>
                </li>
            ))}
        </ul>
        )}

        {link && (
            <a class="text-violet-500 font-medium underline" href={link.href}>{link.text}</a>
        )}

        <div class="flex flex-col md:flex-row">
            {button && (
                <Button variant={buttonVariant} label={buttonLabel}>
                </Button>
            )}
        </div>
    </div>

    <img src={imageUrl} alt={imageAlt} class="w-full h-100 object-cover">
</div>

