---
interface Field {
    name: string;
    label: string;
    type?: 'text' | 'email' | 'password' | 'textarea' | 'number';
    placeholder?: string;
    required?: boolean;
}

interface Props {
    fields: Field[];
    submitLabel?: string;
    onSubmit?: string;
    method?: 'GET' | 'POST';
}

const { 
    fields = [], 
    submitLabel = 'Enviar',
    onSubmit = '#',
    method = 'POST'
} = Astro.props;
---

<form method={method} action={onSubmit} class="flex flex-col gap-6 w-full">
    {fields.map((field) => (
        <div class="flex flex-col gap-2">
            <label 
                for={field.name}
                class="text-sm md:text-base font-medium text-gray-900"
            >
                {field.label}
                {field.required && <span class="text-red-500">*</span>}
            </label>

            {field.type === 'textarea' ? (
                <textarea
                    id={field.name}
                    name={field.name}
                    placeholder={field.placeholder}
                    required={field.required}
                    rows={5}
                    class="px-4 py-2 md:py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-200 transition-all duration-200 resize-none"
                />
            ) : (
                <input
                    id={field.name}
                    type={field.type || 'text'}
                    name={field.name}
                    placeholder={field.placeholder}
                    required={field.required}
                    class="px-4 py-2 md:py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-200 transition-all duration-200"
                />
            )}
        </div>
    ))}

    <button
        type="submit"
        class="bg-violet-500 hover:bg-violet-600 text-white font-semibold rounded-lg py-2 md:py-3 transition-colors duration-200 w-full md:w-auto"
    >
        {submitLabel}
    </button>
</form>

<style>
    input,
    textarea {
        font-family: inherit;
    }

    input:focus-visible,
    textarea:focus-visible {
        outline: none;
    }
</style>
