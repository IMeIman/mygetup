---
interface Props {
    title: string;
    description: string;
    price: string | number;
    period?: string;
    features: string[];
    buttonLabel?: string;
    buttonHref?: string;
    highlighted?: boolean;
}

const {
    title,
    description,
    price,
    period = "mes",
    features = [],
    buttonLabel = "Contratar",
    buttonHref = "#",
    highlighted = false
} = Astro.props;
---

<div class={`flex flex-col rounded-2xl overflow-hidden transition-all duration-300 ${
    highlighted 
        ? 'border-2 border-violet-500 shadow-lg scale-105' 
        : 'border border-gray-200 shadow-md hover:shadow-lg'
}`}>
    {highlighted && (
        <div class="bg-violet-500 text-white text-center py-2 font-semibold text-sm">
            DESTACADO
        </div>
    )}

    <div class="flex flex-col gap-6 p-8 flex-grow">
        <!-- Header -->
        <div class="flex flex-col gap-3">
            <h3 class="text-2xl font-semibold text-gray-900">{title}</h3>
            <p class="text-gray-600">{description}</p>
        </div>

        <!-- Price -->
        <div class="flex items-baseline gap-2">
            <span class="text-4xl font-bold text-gray-900">${price}</span>
            <span class="text-gray-600">/{period}</span>
        </div>

        <!-- Features List -->
        <ul class="flex flex-col gap-3">
            {features.map((feature) => (
                <li class="flex flex-row gap-3 items-start">
                    <div class={`w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 ${
                        highlighted ? 'bg-violet-500' : 'bg-gray-300'
                    }`}>
                        <svg
                            class="w-3 h-3 text-white"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                clip-rule="evenodd"
                            />
                        </svg>
                    </div>
                    <span class="text-gray-700">{feature}</span>
                </li>
            ))}
        </ul>
    </div>

    <!-- Button -->
    <div class="px-8 pb-8">
        <a
            href={buttonHref}
            class={`block w-full text-center font-semibold rounded-lg py-3 transition-all duration-200 ${
                highlighted
                    ? 'bg-violet-500 text-white hover:bg-violet-600'
                    : 'border-2 border-violet-500 text-violet-500 hover:bg-violet-50'
            }`}
        >
            {buttonLabel}
        </a>
    </div>
</div>
